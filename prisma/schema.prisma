generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model about_features {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  description String
  icon_name   String
  sort_order  Int       @default(0)
  is_active   Boolean?  @default(true)
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  updated_at  DateTime? @default(now()) @db.Timestamptz(6)
}

model about_stats {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  value      String
  label      String
  sort_order Int       @default(0)
  is_active  Boolean?  @default(true)
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
}

model addresses {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String?   @db.Uuid
  guest_id      String?
  name          String
  phone         String
  address_line1 String
  city          String
  state         String
  pincode       String
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
  address_line2 String?
  is_default    Boolean?  @default(false)
  updated_at    DateTime? @default(now()) @db.Timestamptz(6)
  orders        orders[]
}

model admin_activity_logs {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  admin_user_id String?   @db.Uuid
  action        String
  entity_type   String?
  entity_id     String?
  metadata      Json?
  ip_address    String?
  user_agent    String?
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model admin_invites {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email      String
  role       String
  token_hash String    @unique
  expires_at DateTime  @db.Timestamptz(6)
  used_at    DateTime? @db.Timestamptz(6)
  invited_by String?
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
  setup_key  String?
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model admin_profiles {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String    @unique
  role        String
  is_active   Boolean?  @default(false)
  approved_by String?
  approved_at DateTime? @db.Timestamptz(6)
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  updated_at  DateTime? @default(now()) @db.Timestamptz(6)
  name        String?
  last_login  DateTime? @db.Timestamptz(6)
  deleted_at  DateTime? @db.Timestamptz(6)
  full_name   String?
  avatar_url  String?
}

model admin_settings {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  setup_completed   Boolean?  @default(false)
  recovery_key_hash String?
  created_at        DateTime? @default(now()) @db.Timestamptz(6)
  updated_at        DateTime? @default(now()) @db.Timestamptz(6)
  singleton_guard   Boolean   @unique @default(true)
}

model audit_logs {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  admin_id    String?   @db.Uuid
  action      String
  entity_type String
  entity_id   String?
  details     Json?
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
}

model banner_analytics {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  banner_id   String    @db.Uuid
  date        DateTime  @default(dbgenerated("CURRENT_DATE")) @db.Date
  clicks      Int?      @default(0)
  impressions Int?      @default(0)
  ctr         Decimal?  @default(0) @db.Decimal
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  updated_at  DateTime? @default(now()) @db.Timestamptz(6)
  banners     banners   @relation(fields: [banner_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model banners {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  internal_title   String
  image_url        String?
  link_url         String?
  placement        String?
  created_at       DateTime?          @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?          @default(now()) @db.Timestamptz(6)
  action_type      String?
  action_target    String?
  action_name      String?
  start_date       DateTime?          @db.Timestamptz(6)
  end_date         DateTime?          @db.Timestamptz(6)
  position         Int?
  category         String?
  cta_text         String?
  status           String?            @default("active")
  clicks           Int?               @default(0)
  impressions      Int?               @default(0)
  ctr              Decimal?           @default(0) @db.Decimal
  carousel_data    Json?
  marquee_data     Json?
  banner_analytics banner_analytics[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model campaign_actions {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaign_id    String    @db.Uuid
  discount_type  String
  discount_value Decimal   @db.Decimal
  max_discount   Decimal?  @db.Decimal
  applies_to     String    @default("cart")
  created_at     DateTime? @default(now()) @db.Timestamptz(6)
  campaigns      campaigns @relation(fields: [campaign_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model campaign_rules {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaign_id String    @db.Uuid
  rule_type   String
  operator    String    @default(">=")
  value       Json
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  campaigns   campaigns @relation(fields: [campaign_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model campaigns {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String
  description      String?
  status           String             @default("draft")
  priority         Int                @default(0)
  start_at         DateTime           @db.Timestamptz(6)
  end_at           DateTime?          @db.Timestamptz(6)
  apply_type       String             @default("auto")
  stackable        Boolean            @default(false)
  created_at       DateTime?          @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?          @default(now()) @db.Timestamptz(6)
  campaign_actions campaign_actions[]
  campaign_rules   campaign_rules[]
  order_discounts  order_discounts[]
}

model cart_items {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String?          @db.Uuid
  guest_id         String?
  variant_id       String           @db.Uuid
  quantity         Int?             @default(1)
  created_at       DateTime?        @default(now()) @db.Timestamptz(6)
  product_variants product_variants @relation(fields: [variant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model categories {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String
  slug               String               @unique
  image              String?
  created_at         DateTime?            @default(now()) @db.Timestamptz(6)
  updated_at         DateTime?            @default(now()) @db.Timestamptz(6)
  meta_title         String?              @db.VarChar
  meta_description   String?
  display_order      Int?                 @default(0)
  icon_url           String?
  status             String?              @default("active")
  image_url          String?
  category_tax_rules category_tax_rules?
  product_categories product_categories[]
  products           products[]
}

model category_tax_rules {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  category_id String     @unique @db.Uuid
  gst_rate    Decimal    @db.Decimal
  created_at  DateTime?  @default(now()) @db.Timestamptz(6)
  updated_at  DateTime?  @default(now()) @db.Timestamptz(6)
  categories  categories @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model cms_pages {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug         String   @unique
  title        String
  content      String
  is_published Boolean? @default(true)
  created_at   DateTime @default(dbgenerated("(now() AT TIME ZONE 'utc'::text)")) @db.Timestamptz(6)
  updated_at   DateTime @default(dbgenerated("(now() AT TIME ZONE 'utc'::text)")) @db.Timestamptz(6)
}

model collections {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title               String
  slug                String                @unique
  description         String?
  type                String
  is_active           Boolean?              @default(true)
  rule_json           Json?
  created_at          DateTime?             @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?             @default(now()) @db.Timestamptz(6)
  homepage_sections   homepage_sections[]
  product_collections product_collections[]
}

model coupons {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code           String    @unique
  discount_type  String
  discount_value Decimal   @db.Decimal
  usage_limit    Int?
  usage_count    Int?      @default(0)
  is_active      Boolean?  @default(true)
  expires_at     DateTime? @db.Timestamptz(6)
  created_at     DateTime? @default(now()) @db.Timestamptz(6)
  updated_at     DateTime? @default(now()) @db.Timestamptz(6)
}

model customer_activity_log {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id   String    @db.Uuid
  activity_type String
  description   String?
  metadata      Json?     @default("{}")
  ip_address    String?   @db.Inet
  user_agent    String?
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
  customers     customers @relation(fields: [customer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model customer_addresses {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id   String    @db.Uuid
  name          String
  phone         String
  email         String?
  address_line1 String
  address_line2 String?
  city          String
  state         String
  pincode       String
  country       String    @default("India")
  address_type  String?   @default("shipping")
  is_default    Boolean?  @default(false)
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
  updated_at    DateTime? @default(now()) @db.Timestamptz(6)
  customers     customers @relation(fields: [customer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model customer_notes {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id String    @db.Uuid
  note        String
  created_by  String    @db.Uuid
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  updated_at  DateTime? @default(now()) @db.Timestamptz(6)
  customers   customers @relation(fields: [customer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model customers {
  id                    String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  auth_user_id          String?                 @unique
  email                 String?
  phone                 String?
  first_name            String?
  last_name             String?
  customer_type         String
  status                String?                 @default("active")
  metadata              Json?                   @default("{}")
  created_at            DateTime?               @default(now()) @db.Timestamptz(6)
  updated_at            DateTime?               @default(now()) @db.Timestamptz(6)
  last_order_at         DateTime?               @db.Timestamptz(6)
  customer_activity_log customer_activity_log[]
  customer_addresses    customer_addresses[]
  customer_notes        customer_notes[]
  orders                orders[]
}

model faqs {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title        String
  question     String
  answer       String
  sort_order   Int      @default(0)
  is_published Boolean  @default(true)
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  updated_at   DateTime @default(now()) @db.Timestamptz(6)
}

model homepage_sections {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title         String
  position      Int
  collection_id String?      @db.Uuid
  layout        String?
  is_active     Boolean?     @default(true)
  start_at      DateTime?    @db.Timestamptz(6)
  end_at        DateTime?    @db.Timestamptz(6)
  created_at    DateTime?    @default(now()) @db.Timestamptz(6)
  updated_at    DateTime?    @default(now()) @db.Timestamptz(6)
  collections   collections? @relation(fields: [collection_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model inventory_items {
  id                  String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  variant_id          String           @unique @db.Uuid
  sku                 String?
  barcode             String?
  quantity            Int?             @default(0)
  available_quantity  Int?             @default(0)
  reserved_quantity   Int?             @default(0)
  cost                Decimal?         @db.Decimal
  track_quantity      Boolean?         @default(true)
  allow_backorders    Boolean?         @default(false)
  low_stock_threshold Int?
  created_at          DateTime?        @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?        @default(now()) @db.Timestamptz(6)
  product_variants    product_variants @relation(fields: [variant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model inventory_logs {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  variant_id       String           @db.Uuid
  change_amount    Int
  reason           String
  created_at       DateTime?        @default(now()) @db.Timestamptz(6)
  product_variants product_variants @relation(fields: [variant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model low_stock_notifications {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id       String            @db.Uuid
  variant_id       String?           @db.Uuid
  product_name     String
  variant_name     String?
  current_stock    Int
  threshold        Int
  notified_at      DateTime?         @db.Timestamptz(6)
  resolved_at      DateTime?         @db.Timestamptz(6)
  created_at       DateTime?         @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?         @default(now()) @db.Timestamptz(6)
  products         products          @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  product_variants product_variants? @relation(fields: [variant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model notification_settings {
  id                          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_confirmation_enabled  Boolean?  @default(true)
  shipment_update_enabled     Boolean?  @default(true)
  low_stock_alert_enabled     Boolean?  @default(true)
  low_stock_threshold         Int?      @default(10)
  refund_notification_enabled Boolean?  @default(true)
  created_at                  DateTime? @default(now()) @db.Timestamptz(6)
  updated_at                  DateTime? @default(now()) @db.Timestamptz(6)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model order_discounts {
  id              String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id        String     @db.Uuid
  campaign_id     String?    @db.Uuid
  discount_type   String
  discount_amount Decimal    @db.Decimal
  applied_at      DateTime?  @default(now()) @db.Timestamptz(6)
  campaigns       campaigns? @relation(fields: [campaign_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  orders          orders     @relation(fields: [order_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model order_items {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id         String           @db.Uuid
  variant_id       String           @db.Uuid
  quantity         Int
  price            Decimal          @db.Decimal
  created_at       DateTime?        @default(now()) @db.Timestamptz(6)
  orders           orders           @relation(fields: [order_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  product_variants product_variants @relation(fields: [variant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model order_status_history {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id   String   @db.Uuid
  status     String
  note       String?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  orders     orders   @relation(fields: [order_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model order_taxes {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id           String    @unique @db.Uuid
  taxable_amount     Decimal   @db.Decimal
  cgst               Decimal?  @default(0) @db.Decimal
  sgst               Decimal?  @default(0) @db.Decimal
  igst               Decimal?  @default(0) @db.Decimal
  total_tax          Decimal   @db.Decimal
  gst_rate           Decimal   @db.Decimal
  tax_type           String
  store_state        String
  customer_state     String
