}

model orders {
  id                           String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                      String?
  guest_id                     String?
  guest_email                  String?
  total_amount                 Decimal                @db.Decimal
  shipping_amount              Decimal?               @db.Decimal
  shipping_address_id          String?                @db.Uuid
  shipping_zone                String?
  shipping_provider            String?
  shipping_tracking_number     String?
  order_status                 String?                @default("pending")
  payment_status               String?                @default("pending")
  razorpay_order_id            String?
  created_at                   DateTime?              @default(now()) @db.Timestamptz(6)
  updated_at                   DateTime?              @default(now()) @db.Timestamptz(6)
  customer_id                  String?
  customer_email_snapshot      String?
  customer_phone_snapshot      String?
  customer_name_snapshot       String?
  subtotal_amount              Decimal?               @db.Decimal
  tax_amount                   Decimal?               @db.Decimal
  shipping_address             Json?
  shipping_method              String?
  payment_method               String?
  tax_details                  Json?
  coupon_code                  String?
  discount_amount              Decimal?               @default(0) @db.Decimal
  shipped_at                   DateTime?              @db.Timestamptz(6)
  delivered_at                 DateTime?              @db.Timestamptz(6)
  abandoned_cart_email_sent_at DateTime?              @db.Timestamptz(6)
  order_discounts              order_discounts[]
  order_items                  order_items[]
  order_status_history         order_status_history[]
  order_taxes                  order_taxes?
  addresses                    addresses?             @relation(fields: [shipping_address_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customers                    customers?             @relation(fields: [customer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  payments                     payments[]
  returns                      returns[]
}

model payment_settings {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  razorpay_enabled    Boolean?  @default(false)
  razorpay_key_id     String?
  razorpay_key_secret String?
  razorpay_test_mode  Boolean?  @default(true)
  cod_enabled         Boolean?  @default(true)
  cod_max_amount      Decimal?  @default(0) @db.Decimal
  payment_methods     String[]  @default(["cod", "razorpay"])
