model product_images {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id String    @db.Uuid
  image_url  String
  alt_text   String?
  is_primary Boolean?  @default(false)
  sort_order Int?
  width      Int?
  height     Int?
